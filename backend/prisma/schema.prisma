generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TagType {
  CONTEXT
  MOOD
}

enum Visibility {
  PRIVATE
  FRIENDS
  PUBLIC
}

enum LyricsFetchStatus {
  IDLE
  FETCHING
  DONE
  FAILED
}

enum FeatureStatus {
  DRAFT
  MUST_HAVE
  WORKING_ON_IT
  DONE
  DECLINED
}

enum LyricsStatus {
  DRAFT
  WORK_IN_PROGRESS
  FINISHED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  spotifyTokens       SpotifyToken[]
  savedLyrics         SavedLyric[]
  searchHistory       SearchHistory[]
  lineAnnotations     LineAnnotation[]
  songNotes           SongNote[]
  collections         Collection[]
  digests             Digest[]
  featureRequests     FeatureRequest[]
  featureRequestVotes FeatureRequestVote[]
  playHistory         PlayHistory[]
}

model SpotifyToken {
  id           String   @id @default(cuid())
  userId       String   @unique
  spotifyId    String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── NEW: Shared canonical entity per spotifyId ───────────────────────────────

model Song {
  id          String            @id @default(cuid())
  spotifyId   String            @unique
  title       String
  artist      String
  artists     String[]          @default([])
  imgUrl      String?
  spotifyUrl  String?
  videoUrl    String?
  fetchStatus   LyricsFetchStatus @default(IDLE)
  audioFeatures Json?            // { tempo, energy, valence, danceability } from Spotify audio-features API
  firstSeenAt   DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  lyrics  SongLyrics?
  tags    SongTag[]
  notes   SongNote[]
  savedBy SavedLyric[]
}

// ─── NEW: Shared lyrics document per Song ─────────────────────────────────────

model SongLyrics {
  id           String       @id @default(cuid())
  songId       String       @unique
  rawText      String       @default("")
  version      Int          @default(1)
  lastEditedBy String?
  lrclibSource Boolean      @default(false)
  status       LyricsStatus @default(DRAFT)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  song     Song             @relation(fields: [songId], references: [id], onDelete: Cascade)
  lines    LyricsLine[]
  versions LyricsVersion[]
  sections LyricsSection[]
}

model LyricsSection {
  id           String   @id @default(cuid())
  songLyricsId String
  label        String
  startLine    Int
  position     Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  songLyrics SongLyrics @relation(fields: [songLyricsId], references: [id], onDelete: Cascade)

  @@index([songLyricsId, position])
}

model SavedLyric {
  id              String            @id @default(cuid())
  userId          String
  searchHistoryId String?
  spotifyId       String?
  lyrics          String            @default("")
  track           String            @default("")
  artist          String            @default("")
  artists         String[]          @default([])
  note            String?
  videoUrl        String?
  isFavorite      Boolean           @default(false)
  visibility      Visibility        @default(PRIVATE)
  fetchStatus     LyricsFetchStatus @default(IDLE)
  artistColors    Json?
  createdAt       DateTime          @default(now())

  // NEW: reference to shared Song
  songId String?

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  searchHistory    SearchHistory?    @relation(fields: [searchHistoryId], references: [id])
  song             Song?             @relation(fields: [songId], references: [id])
  lyricsStructured Lyrics?
  listeningContext ListeningContext?
  tags             SongTag[]
  collectionItems  CollectionItem[]

  @@unique([userId, spotifyId])
  @@unique([userId, songId])
}

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String
  spotifyId String
  track     String
  artist    String
  artists   String[] @default([])
  url       String
  imgUrl    String?
  createdAt DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedLyrics SavedLyric[]
}

model LibraryTrack {
  id          String   @id @default(cuid())
  spotifyId   String   @unique
  name        String
  artist      String
  artists     String[] @default([])
  imgUrl      String?
  url         String
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @updatedAt
}

// ─── Phase 1: Structured Lyrics ──────────────────────────────────────────────

model Lyrics {
  id           String   @id @default(cuid())
  savedLyricId String   @unique
  rawText      String   @default("")
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  savedLyric SavedLyric     @relation(fields: [savedLyricId], references: [id], onDelete: Cascade)
  lines      LyricsLine[]
  versions   LyricsVersion[]
}

model LyricsLine {
  id          String   @id @default(cuid())
  lyricsId    String?
  lineNumber  Int
  text        String
  timestampMs Int?
  singer      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // NEW: reference to SongLyrics (populated by migration script)
  songLyricsId String?

  lyrics          Lyrics?          @relation(fields: [lyricsId], references: [id], onDelete: Cascade)
  songLyrics      SongLyrics?      @relation(fields: [songLyricsId], references: [id], onDelete: Cascade)
  annotations     LineAnnotation[]
  collectionItems CollectionItem[]

  @@index([lyricsId, lineNumber])
  @@index([songLyricsId, lineNumber])
}

model LyricsVersion {
  id           String   @id @default(cuid())
  lyricsId     String?
  songLyricsId String?
  version      Int
  rawText      String
  createdAt    DateTime @default(now())

  lyrics     Lyrics?     @relation(fields: [lyricsId], references: [id], onDelete: Cascade)
  songLyrics SongLyrics? @relation(fields: [songLyricsId], references: [id], onDelete: Cascade)

  @@index([lyricsId, version])
  @@index([songLyricsId, version])
}

// ─── Phase 1: Personal Meaning Layer ─────────────────────────────────────────

model LineAnnotation {
  id        String   @id @default(cuid())
  lineId    String
  userId    String
  text      String
  emoji     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  line LyricsLine @relation(fields: [lineId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lineId])
  @@index([lineId])
}

model SongTag {
  id           String   @id @default(cuid())
  savedLyricId String?
  tag          String
  type         TagType  @default(CONTEXT)
  createdAt    DateTime @default(now())

  // NEW: shared song reference (populated by migration script)
  songId  String?
  addedBy String?

  savedLyric SavedLyric? @relation(fields: [savedLyricId], references: [id], onDelete: Cascade)
  song       Song?        @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([savedLyricId, tag])
  @@unique([songId, tag])
  @@index([tag])
}

// ─── Shared song commentary ─────────────────────────────────────────────────

model SongNote {
  id        String   @id @default(cuid())
  songId    String
  userId    String
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, songId])
  @@index([songId])
}

// ─── Phase 3: Listening Context ──────────────────────────────────────────────

model ListeningContext {
  id           String   @id @default(cuid())
  savedLyricId String   @unique
  hour         Int      // 0-23
  dayOfWeek    Int      // 0 (Sun) – 6 (Sat)
  deviceType   String?  // "smartphone" | "computer" | "speaker" etc.
  savedAt      DateTime @default(now())

  savedLyric SavedLyric @relation(fields: [savedLyricId], references: [id], onDelete: Cascade)
}

// ─── Phase 4: Weekly Digest ───────────────────────────────────────────────────

model Digest {
  id        String   @id @default(cuid())
  userId    String
  weekStart DateTime
  content   Json
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId])
}

// ─── Phase 2: Collections ─────────────────────────────────────────────────────

model Collection {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CollectionItem[]

  @@index([userId])
}

model CollectionItem {
  id           String   @id @default(cuid())
  collectionId String
  savedLyricId String?
  lineId       String?
  position     Int
  addedAt      DateTime @default(now())

  collection Collection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  savedLyric SavedLyric? @relation(fields: [savedLyricId], references: [id], onDelete: SetNull)
  line       LyricsLine? @relation(fields: [lineId], references: [id], onDelete: SetNull)

  @@index([collectionId, position])
}

// ─── Play History ─────────────────────────────────────────────────────────────

model PlayHistory {
  id        String   @id @default(cuid())
  userId    String
  spotifyId String
  track     String
  artist    String
  artists   String[] @default([])
  imgUrl    String?
  playedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, playedAt(sort: Desc)])
  @@index([spotifyId])
}

// ─── Feature Requests ─────────────────────────────────────────────────────────

model FeatureRequest {
  id        String        @id @default(cuid())
  userId    String
  kind      String        @default("feature")  // "feature" | "bug"
  title     String?
  content   String
  page      String?
  status    FeatureStatus @default(DRAFT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes FeatureRequestVote[]

  @@index([status])
  @@index([createdAt])
}

model FeatureRequestVote {
  id        String @id @default(cuid())
  userId    String
  requestId String

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  request FeatureRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([userId, requestId])
}
